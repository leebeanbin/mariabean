# Docker Compose - Environment Variables Template
# cp .env.example .env 후 값 채워서 사용
# .env 파일은 git에 올리지 않음

# PostgreSQL
POSTGRES_DB=reservation_db
POSTGRES_USER=your_pg_user
POSTGRES_PASSWORD=your_pg_password
POSTGRES_AUTH_METHOD=md5        # 패스워드 있으면 md5, 없으면 trust
POSTGRES_PORT=5433              # 로컬 네이티브 5432와 충돌 방지

# MongoDB
MONGO_DB=reservation
MONGO_PORT=27018                # 로컬 네이티브 27017과 충돌 방지

# Redis
REDIS_PORT=6380                 # 로컬 네이티브 6379와 충돌 방지

# Elasticsearch
ES_PORT=9200

# Kafka
KAFKA_PORT=9092
KAFKA_CLUSTER_ID=your_kafka_cluster_id

# ----------------------------------------
# Spring Boot application env (required)
# ----------------------------------------

# Database / infra endpoints (app uses these names)
postgreUrl=jdbc:postgresql://localhost:5433/reservation_db
postgreUser=your_pg_user
postgrePwd=your_pg_password
mongoUri=mongodb://localhost:27018/reservation
redisHost=localhost
redisPort=6380
elasticsearchUri=http://localhost:9200
kafkaBootstrapServers=localhost:9092

# JWT (minimum 32 bytes)
jwtSecret=change_this_to_at_least_32_bytes_secure_secret

# Frontend origin (CORS / OAuth redirect base)
FRONTEND_URL=http://localhost:3000

# OAuth2 (Kakao/Google)
kakaoClientId=YOUR_KAKAO_CLIENT_ID
kakaoClientSecret=YOUR_KAKAO_CLIENT_SECRET
googleClientId=YOUR_GOOGLE_CLIENT_ID
googleClientSecret=YOUR_GOOGLE_CLIENT_SECRET

# External map/search providers used by backend MapService
googleMapsApiKey=YOUR_GOOGLE_MAPS_API_KEY
kakaoRestApiKey=YOUR_KAKAO_REST_API_KEY

# ----------------------------------------
# AI 검색 (Spring AI + Ollama)
# ----------------------------------------

# Ollama 서버 (docker-compose ollama 서비스 포트)
OLLAMA_PORT=11434
ollamaBaseUrl=http://localhost:11434
ollamaChatModel=qwen2.5:7b
ollamaEmbedModel=nomic-embed-text

# Tavily AI 웹 검색 (선택, 무료 플랜: 월 1,000회)
# https://app.tavily.com에서 발급
TAVILY_API_KEY=

# 알림 채널 (gmail | kakao | log)
NOTIFICATION_CHANNEL=gmail
EMAIL_ADMIN_MEMBER_ID=0

# Optional: Kakao messaging channels
kakaoAlimtalkProvider=GENERIC
kakaoAlimtalkEnabled=false
kakaoAlimtalkEndpoint=
kakaoAlimtalkToken=
kakaoAlimtalkApiKey=
kakaoAlimtalkSenderKey=
kakaoAlimtalkTemplateCode=

kakaoTalkMessageEnabled=false
kakaoTalkMessageEndpoint=
kakaoTalkMessageToken=
kakaoTalkMessageApiKey=
kakaoTalkMessageTemplateCode=
